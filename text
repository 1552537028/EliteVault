// src/pages/ProductPage.jsx
import React, { useEffect, useState, useRef } from "react";
import { useParams, useNavigate } from "react-router-dom";
import { useCart } from "../context/CartContext";

const API_URL = "http://localhost:5000/api/products/product/";
const PAYMENT_API = "http://localhost:5000/api/orders/create-session";
const USER_API = "http://localhost:5000/api/auth/user";
const ADDRESSES_API = "http://localhost:5000/api/auth/address/";
const UPDATE_STOCK_API = "http://localhost:5000/api/products/update-stock/";
const REVIEWS_API = "http://localhost:5000/api/reviews";

const ProductPage = () => {
  const { id } = useParams();
  const navigate = useNavigate();
  const { addToCart } = useCart();

  const [product, setProduct] = useState(null);
  const [reviews, setReviews] = useState([]);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState(null);

  const [selectedImage, setSelectedImage] = useState(null);
  const [quantity, setQuantity] = useState(1);
  const [selectedColor, setSelectedColor] = useState("");
  const [selectedSize, setSelectedSize] = useState("");

  // Review form
  const [rating, setRating] = useState(0);
  const [comment, setComment] = useState("");
  const [submittingReview, setSubmittingReview] = useState(false);
  const [hasReviewed, setHasReviewed] = useState(false);

  // UI states
  const [zoomActive, setZoomActive] = useState(false);
  const [zoomPosition, setZoomPosition] = useState({ x: 0, y: 0 });
  const [showSizeGuide, setShowSizeGuide] = useState(false);

  const imageRef = useRef(null);

  useEffect(() => {
    const fetchData = async () => {
      try {
        // Product
        const prodRes = await fetch(`${API_URL}${id}`);
        if (!prodRes.ok) throw new Error("Product not found");
        const prodData = await prodRes.json();
        setProduct(prodData);

        if (prodData.image_urls?.length) setSelectedImage(prodData.image_urls[0]);
        if (prodData.colors?.length) setSelectedColor(prodData.colors[0]);
        if (prodData.sizes?.length) setSelectedSize(prodData.sizes[0]);

        // Reviews
        const revRes = await fetch(`${REVIEWS_API}/${id}`);
        if (revRes.ok) {
          const revData = await revRes.json();
          setReviews(revData);
        }

        // Check if user already reviewed
        const token = localStorage.getItem("token");
        if (token) {
          const checkRes = await fetch(`${REVIEWS_API}/user-has-reviewed/${id}`, {
            headers: { Authorization: `Bearer ${token}` },
          });
          if (checkRes.ok) {
            const { hasReviewed } = await checkRes.json();
            setHasReviewed(hasReviewed);
          }
        }
      } catch (err) {
        setError(err.message);
      } finally {
        setLoading(false);
      }
    };

    fetchData();
  }, [id]);

  // Zoom handlers
  const handleMouseMove = (e) => {
    if (!zoomActive || !imageRef.current) return;
    const rect = imageRef.current.getBoundingClientRect();
    const x = ((e.clientX - rect.left) / rect.width) * 100;
    const y = ((e.clientY - rect.top) / rect.height) * 100;
    setZoomPosition({ x, y });
  };

  // Quantity controls
  const handleQuantityChange = (e) => {
    const val = parseInt(e.target.value, 10);
    if (!isNaN(val) && val >= 1 && val <= (product?.stock || 1)) {
      setQuantity(val);
    }
  };

  const increment = () => {
    if (quantity < (product?.stock || 1)) setQuantity((q) => q + 1);
  };

  const decrement = () => {
    if (quantity > 1) setQuantity((q) => q - 1);
  };

  // Add to Cart
  const handleAddToCart = () => {
    if (product?.colors?.length > 0 && !selectedColor) return alert("Please select a color");
    if (product?.sizes?.length > 0 && !selectedSize) return alert("Please select a size");
    if (quantity < 1 || quantity > product.stock) return alert("Invalid quantity");

    addToCart({
      ...product,
      quantity,
      selectedColor,
      selectedSize,
    });
    alert("Added to cart!");
  };

  // Buy Now (same logic as before, shortened for brevity)
  const handleBuyNow = async () => {
    if (product?.colors?.length > 0 && !selectedColor) return alert("Please select a color");
    if (product?.sizes?.length > 0 && !selectedSize) return alert("Please select a size");

    const token = localStorage.getItem("token");
    if (!token) {
      alert("Please login to continue");
      return navigate("/login");
    }

    try {
      const userRes = await fetch(USER_API, { headers: { Authorization: `Bearer ${token}` } });
      if (!userRes.ok) throw new Error("Failed to get user");
      const user = await userRes.json();

      const addrRes = await fetch(`${ADDRESSES_API}${user.id}`, {
        headers: { Authorization: `Bearer ${token}` },
      });
      if (!addrRes.ok) throw new Error("Failed to get addresses");
      const addresses = await addrRes.json();
      if (addresses.length === 0) {
        alert("Please add an address first");
        return navigate("/profile");
      }

      const paymentRes = await fetch(PAYMENT_API, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          Authorization: `Bearer ${token}`,
        },
        body: JSON.stringify({
          productId: id,
          total_price: Number(product.price) * quantity,
          userId: user.id,
          addressId: addresses[0].id,
          quantity,
          color: selectedColor || null,
          size: selectedSize || null,
        }),
      });

      if (!paymentRes.ok) throw new Error("Payment failed");

      const { sessionId, orderId } = await paymentRes.json();

      // Cashfree checkout (same as before)
      const loadCashfree = () => new Promise((res) => {
        if (window.Cashfree) return res();
        const script = document.createElement("script");
        script.src = "https://sdk.cashfree.com/js/v3/cashfree.js";
        script.onload = res;
        document.body.appendChild(script);
      });

      await loadCashfree();
      const cashfree = window.Cashfree({ mode: "sandbox" });

      cashfree.checkout({
        paymentSessionId: sessionId,
        returnUrl: `http://localhost:5173/payment-status?orderId=${orderId}`,
      }).then(async (result) => {
        if (result.paymentDetails?.paymentStatus === "SUCCESS") {
          await fetch(`http://localhost:5000/api/orders/verify-payment/${orderId}`, {
            headers: { Authorization: `Bearer ${token}` },
          });

          await fetch(`${UPDATE_STOCK_API}${id}`, {
            method: "PATCH",
            headers: {
              "Content-Type": "application/json",
              Authorization: `Bearer ${token}`,
            },
            body: JSON.stringify({ quantity: product.stock - quantity }),
          });
          navigate(`/order-success/${orderId}`);
        }
      });
    } catch (err) {
      alert("Error: " + err.message);
    }
  };

  // Submit Review
  const handleSubmitReview = async (e) => {
    e.preventDefault();
    if (rating < 1 || rating > 5) return alert("Please select a rating");
    if (!comment.trim()) return alert("Please write a comment");

    const token = localStorage.getItem("token");
    if (!token) {
      alert("Please login to review");
      return navigate("/login");
    }

    setSubmittingReview(true);

    try {
      const res = await fetch(REVIEWS_API, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          Authorization: `Bearer ${token}`,
        },
        body: JSON.stringify({ productId: id, rating, comment: comment.trim() }),
      });

      if (!res.ok) {
        const err = await res.json();
        throw new Error(err.error || "Failed to submit");
      }

      const newReview = await res.json();
      setReviews([newReview, ...reviews]);
      setHasReviewed(true);
      setRating(0);
      setComment("");
      alert("Review submitted!");
    } catch (err) {
      alert(err.message);
    } finally {
      setSubmittingReview(false);
    }
  };

  if (loading) return <div className="text-center py-20 text-xl">Loading product...</div>;
  if (error || !product) return <div className="text-center py-20 text-red-600">Product not found</div>;

  return (
    <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 lg:py-12 bg-gray-50 min-h-screen">
      <div className="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16">
        {/* Images + Zoom */}
        <div className="space-y-6">
          <div
            className="relative overflow-hidden rounded-xl shadow-xl border border-gray-200 bg-white cursor-zoom-in"
            onMouseEnter={() => setZoomActive(true)}
            onMouseLeave={() => setZoomActive(false)}
            onMouseMove={handleMouseMove}
            ref={imageRef}
          >
            <img
              src={`http://localhost:5000${selectedImage || product.image_urls?.[0] || ""}`}
              alt={product.name}
              className="w-full h-96 lg:h-[520px] object-contain transition-transform duration-150"
              style={{
                transform: zoomActive ? "scale(2.2)" : "scale(1)",
                transformOrigin: `${zoomPosition.x}% ${zoomPosition.y}%`,
              }}
            />
          </div>

          {product.image_urls?.length > 1 && (
            <div className="flex gap-3 overflow-x-auto pb-2 scrollbar-thin scrollbar-thumb-gray-300">
              {product.image_urls.map((img, idx) => (
                <button
                  key={idx}
                  onClick={() => setSelectedImage(img)}
                  className={`flex-shrink-0 rounded-lg overflow-hidden border-2 transition-all duration-200 ${
                    selectedImage === img
                      ? "border-[#C6A75E] scale-105 shadow-md"
                      : "border-transparent hover:border-gray-300"
                  }`}
                >
                  <img src={`http://localhost:5000${img}`} alt="" className="w-20 h-20 object-cover" />
                </button>
              ))}
            </div>
          )}
        </div>

        {/* Product Info */}
        <div className="space-y-7">
          <div>
            <h1 className="text-3xl lg:text-4xl font-bold text-gray-900">{product.name}</h1>
            {product.category && <p className="text-gray-600 mt-2 font-medium">{product.category}</p>}
          </div>

          <div className="flex items-center gap-4">
            <span className="text-4xl lg:text-5xl font-bold text-gray-900">
              ₹{Number(product.price).toFixed(0)}
            </span>
            {product.offer > 0 && (
              <>
                <span className="text-2xl text-gray-500 line-through">
                  ₹{Math.round(product.price + product.offer)}
                </span>
                <span className="bg-green-100 text-green-700 px-3 py-1 rounded-full text-sm font-semibold">
                  {Math.round((product.offer / (product.price + product.offer)) * 100)}% OFF
                </span>
              </>
            )}
          </div>

          {product.stock <= 0 ? (
            <p className="text-red-600 font-semibold text-lg">Out of stock</p>
          ) : product.stock < 10 ? (
            <p className="text-orange-600 font-semibold">Only {product.stock} left – hurry!</p>
          ) : null}

          {/* Color */}
          {product.colors?.length > 0 && (
            <div className="space-y-3">
              <label className="block text-lg font-semibold text-gray-900">Color</label>
              <div className="flex flex-wrap gap-4">
                {product.colors.map((color) => (
                  <button
                    key={color}
                    onClick={() => setSelectedColor(color)}
                    title={color}
                    className={`group relative w-11 h-11 rounded-full border-2 transition-all duration-200 shadow-sm ${
                      selectedColor === color
                        ? "border-[#C6A75E] ring-2 ring-[#C6A75E]/30 scale-110"
                        : "border-gray-300 hover:border-gray-400 hover:scale-105"
                    }`}
                    style={{ backgroundColor: color.toLowerCase() === "white" ? "#fefefe" : color.toLowerCase() }}
                  >
                    <span className="absolute -bottom-8 left-1/2 -translate-x-1/2 text-xs font-medium text-gray-700 opacity-0 group-hover:opacity-100 transition-opacity">
                      {color}
                    </span>
                  </button>
                ))}
              </div>
            </div>
          )}

          {/* Size */}
          {product.sizes?.length > 0 && (
            <div className="space-y-3">
              <div className="flex items-center justify-between">
                <label className="block text-lg font-semibold text-gray-900">Size</label>
                <button
                  onClick={() => setShowSizeGuide(true)}
                  className="text-sm text-[#C6A75E] hover:underline font-medium"
                >
                  Size Guide →
                </button>
              </div>
              <div className="flex flex-wrap gap-3">
                {product.sizes.map((size) => (
                  <button
                    key={size}
                    onClick={() => setSelectedSize(size)}
                    className={`px-6 py-2.5 min-w-[60px] border rounded-md font-medium transition-all ${
                      selectedSize === size
                        ? "bg-[#1C1C1C] text-white border-[#1C1C1C] shadow-md"
                        : "border-gray-300 hover:border-gray-500 hover:bg-gray-50"
                    }`}
                  >
                    {size}
                  </button>
                ))}
              </div>
            </div>
          )}

          {/* Quantity */}
          <div className="space-y-3">
            <label className="block text-lg font-semibold text-gray-900">Quantity</label>
            <div className="flex items-center gap-5">
              <div className="flex border border-gray-300 rounded-md overflow-hidden">
                <button
                  onClick={decrement}
                  className="px-5 py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-800 font-bold disabled:opacity-40"
                  disabled={quantity <= 1}
                >
                  −
                </button>
                <input
                  type="number"
                  min="1"
                  max={product.stock || 1}
                  value={quantity}
                  onChange={handleQuantityChange}
                  className="w-20 text-center border-none focus:ring-0 py-2.5 text-lg"
                />
                <button
                  onClick={increment}
                  className="px-5 py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-800 font-bold disabled:opacity-40"
                  disabled={quantity >= (product.stock || 1)}
                >
                  +
                </button>
              </div>
              <span className="text-gray-600 font-medium">
                {product.stock > 0 ? `${product.stock} in stock` : "Out of stock"}
              </span>
            </div>
          </div>

          {/* Actions */}
          <div className="flex flex-col sm:flex-row gap-4 pt-4">
            <button
              onClick={handleBuyNow}
              disabled={product.stock <= 0}
              className="flex-1 bg-[#1C1C1C] text-white py-4 px-8 rounded-lg font-bold text-lg hover:bg-black transition disabled:opacity-50 disabled:cursor-not-allowed shadow-md"
            >
              BUY NOW
            </button>
            <button
              onClick={handleAddToCart}
              disabled={product.stock <= 0}
              className="flex-1 border-2 border-[#C6A75E] text-[#C6A75E] py-4 px-8 rounded-lg font-bold text-lg hover:bg-[#C6A75E] hover:text-white transition disabled:opacity-50 disabled:cursor-not-allowed"
            >
              ADD TO CART
            </button>
          </div>

          {/* Description */}
          {product.description && (
            <div className="pt-8 border-t border-gray-200">
              <h3 className="text-xl font-semibold mb-4">Description</h3>
              <p className="text-gray-700 leading-relaxed whitespace-pre-line">
                {product.description}
              </p>
            </div>
          )}

          {/* Reviews */}
          <div className="pt-10 border-t border-gray-200">
            <h2 className="text-2xl font-bold mb-6 flex items-center gap-3">
              Customer Reviews
              {product.avg_rating > 0 && (
                <span className="text-xl font-semibold text-yellow-500">
                  {product.avg_rating.toFixed(1)} ★
                </span>
              )}
              <span className="text-gray-500 text-lg">({reviews.length})</span>
            </h2>

            {reviews.length === 0 ? (
              <p className="text-gray-600 italic">No reviews yet. Be the first to share your thoughts!</p>
            ) : (
              <div className="space-y-8">
                {reviews.map((review) => (
                  <div key={review.id} className="border-b pb-6 last:border-b-0">
                    <div className="flex items-center gap-2 mb-2">
                      {[...Array(5)].map((_, i) => (
                        <span
                          key={i}
                          className={`text-2xl ${i < review.rating ? "text-yellow-400" : "text-gray-200"}`}
                        >
                          ★
                        </span>
                      ))}
                      <span className="text-sm text-gray-500 ml-3">
                        {new Date(review.created_at).toLocaleDateString("en-IN", {
                          day: "numeric",
                          month: "short",
                          year: "numeric",
                        })}
                      </span>
                    </div>
                    <p className="text-gray-800 leading-relaxed">{review.comment}</p>
                    <p className="text-sm text-gray-600 mt-2 font-medium">
                      — {review.user_name || "Anonymous"}
                    </p>
                  </div>
                ))}
              </div>
            )}

            {/* Review Form */}
            {!hasReviewed && (
              <div className="mt-12 bg-white p-7 rounded-xl border border-gray-200 shadow-sm">
                <h3 className="text-xl font-semibold mb-5">Write a Review</h3>
                <form onSubmit={handleSubmitReview} className="space-y-6">
                  <div>
                    <label className="block mb-3 font-medium text-gray-800">Your Rating</label>
                    <div className="flex gap-1">
                      {[1, 2, 3, 4, 5].map((star) => (
                        <button
                          type="button"
                          key={star}
                          onClick={() => setRating(star)}
                          className={`text-4xl transition-transform hover:scale-110 ${
                            star <= rating ? "text-yellow-400" : "text-gray-200 hover:text-yellow-300"
                          }`}
                        >
                          ★
                        </button>
                      ))}
                    </div>
                  </div>

                  <div>
                    <label className="block mb-3 font-medium text-gray-800">Your Review</label>
                    <textarea
                      value={comment}
                      onChange={(e) => setComment(e.target.value)}
                      rows={4}
                      className="w-full border border-gray-300 rounded-lg p-4 focus:ring-2 focus:ring-[#C6A75E] focus:border-[#C6A75E] outline-none resize-none"
                      placeholder="What did you like? Any suggestions?..."
                      required
                      minLength={10}
                    />
                  </div>

                  <button
                    type="submit"
                    disabled={submittingReview}
                    className="bg-[#1C1C1C] text-white px-8 py-3.5 rounded-lg font-semibold hover:bg-black transition disabled:opacity-60 shadow-sm"
                  >
                    {submittingReview ? "Submitting..." : "Submit Review"}
                  </button>
                </form>
              </div>
            )}
          </div>
        </div>
      </div>

      {/* Size Guide Modal */}
      {showSizeGuide && (
        <div
          className="fixed inset-0 bg-black/60 flex items-center justify-center z-50 p-4"
          onClick={() => setShowSizeGuide(false)}
        >
          <div
            className="bg-white rounded-2xl max-w-lg w-full p-8 relative"
            onClick={(e) => e.stopPropagation()}
          >
            <button
              onClick={() => setShowSizeGuide(false)}
              className="absolute top-5 right-6 text-3xl text-gray-500 hover:text-gray-800"
            >
              ×
            </button>

            <h2 className="text-2xl font-bold mb-6 text-center">Size Guide</h2>

            <p className="text-gray-700 mb-6 text-center">
              Measurements are approximate. Choose based on your usual fit.
            </p>

            <div className="overflow-x-auto">
              <table className="w-full text-left border-collapse">
                <thead>
                  <tr className="bg-gray-100">
                    <th className="p-4 font-semibold">Size</th>
                    <th className="p-4 font-semibold">Chest (inches)</th>
                    <th className="p-4 font-semibold">Length (inches)</th>
                  </tr>
                </thead>
                <tbody>
                  <tr className="border-t">
                    <td className="p-4">S</td>
                    <td className="p-4">36–38</td>
                    <td className="p-4">27</td>
                  </tr>
                  <tr className="border-t">
                    <td className="p-4">M</td>
                    <td className="p-4">38–40</td>
                    <td className="p-4">28</td>
                  </tr>
                  <tr className="border-t">
                    <td className="p-4">L</td>
                    <td className="p-4">40–42</td>
                    <td className="p-4">29</td>
                  </tr>
                  <tr className="border-t">
                    <td className="p-4">XL</td>
                    <td className="p-4">42–44</td>
                    <td className="p-4">30</td>
                  </tr>
                </tbody>
              </table>
            </div>

            <p className="mt-6 text-sm text-gray-500 text-center">
              * Actual product measurements may vary slightly by style.
            </p>
          </div>
        </div>
      )}
    </div>
  );
};

export default ProductPage;







